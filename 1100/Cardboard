#define ip(x) for(auto &it:x)cin>>it
#define op(x) for(auto &it:x) cout<<it<<" "




void solve()
{
	ll n,cons;
	cin>>n>>cons;
	
	vll v(n,0);
	ip(v);
	
	ll a = 4 * n;
	ll b = 0,c = 0;
	
	for(int i=0;i<n;i++)
	{
	    b = b+ (v[i]*4);
	    c += (v[i]*v[i]);
	}
// 	c = c;
	ll i = 1,j = 1e18,res=0;
	while(i<=j)
	{
	    ll mid = (i) + (j-i)/2;
	    
	    ll ans = ((((cons-c)-b*mid)/mid)/a);
	    
	  
	     if(ans>=mid)
	     {
	         res= mid;
	        i = mid+1;
	     }
	    else
	    j = mid-1;
	  
	}
	cout<<res<<endl;
	
// 	cout<<ans<<endl;
	


}



int main()
{
	int t=1;
	cin>>t;
	while(t--)solve();
	return 0;
}




